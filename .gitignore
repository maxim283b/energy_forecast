# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]

# C extensions
*.so

# Distribution / packaging
.Python
venv/
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover

# Translations
*.mo
*.pot

# Django stuff:
*.log

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# DotEnv configuration
.env

# Database
*.db
*.rdb

# Pycharm
.idea

# VS Code
# .vscode/

# Spyder
.spyproject/

# Jupyter NB Checkpoints
.ipynb_checkpoints/

# exclude data from source control by default
/data/*
!/data/raw/
!/data/processed/

# Mac OS-specific storage files
.DS_Store

# vim
*.swp
*.swo

# Mypy cache
.mypy_cache/
# DVC files (keep .gitignore for tracking)
!*.dvc
!/data/**/.gitignore
# --- MLOps Specific ---

# MLflow local data and logs
mlruns/
mlflow_data/
mlflow.db
.method_cache/

# Optimization logs (Optuna/etc)
optuna.db

# Large data files (даже если папки разрешены, файлы внутри лучше исключить)
data/**/*.csv
data/**/*.parquet
data/**/*.json
!data/**/.gitkeep

# Исключаем временные модели, если они не в dvc
data/models/*.json
data/models/*.xgb
data/models/*.mlmodel

# Plots (если хочешь хранить их только в MLflow)
data/plots/*.png